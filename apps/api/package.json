{
  "name": "@flashsale/api",
  "version": "1.0.0",
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test:unit": "TMPDIR=/tmp vitest run test/unit",
    "test:integration": "TMPDIR=/tmp vitest run test/integration",
    "test:concurrency": "TMPDIR=/tmp vitest run test/integration/concurrency.spec.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@flashsale/shared": "1.0.0",
    "fastify": "^5.0.0",
    "ioredis": "^5.4.1",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.8.6",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
