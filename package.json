{
  "name": "flash-sale-system",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @flashsale/shared && npm run build -w @flashsale/api && npm run build -w @flashsale/web",
    "up": "docker compose up --build",
    "down": "docker compose down -v",
    "logs": "docker compose logs -f --tail=200",
    "test:unit": "npm run test:unit -w @flashsale/api",
    "test:integration": "npm run test:integration -w @flashsale/api",
    "test:concurrency": "npm run test:concurrency -w @flashsale/api",
    "stress": "k6 run stress/purchase.js"
  }
}
